{
  "name": "abc-luxury-tiles-root",
  "version": "1.0.0",
  "description": "Root workspace for ABC Luxury Tiles",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:backend": "node backend/server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
